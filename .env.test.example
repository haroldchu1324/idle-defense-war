# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test to git.

# ── Dedicated QA test accounts (email login tests) ───────────────────────────
# Two separate accounts that must already exist in your Supabase project.
# Do NOT use your personal / production accounts.
TEST_EMAIL_A=qa-account-a@example.com
TEST_PASSWORD_A=your-password-here

TEST_EMAIL_B=qa-account-b@example.com
TEST_PASSWORD_B=your-password-here

# ── Supabase Service Role Key (guest cleanup) ─────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# Used ONLY to delete guest accounts created during tests.
# Keep this secret — it bypasses Row Level Security.
TEST_SUPABASE_SERVICE_KEY=eyJ...your-service-role-key-here
